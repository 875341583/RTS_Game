[rendering]

renderer/rendering_method="mobile"
anti_aliasing/quality/msaa_2d="disabled"
anti_aliasing/quality/msaa_3d="disabled"
lights_and_shadows/directional_shadow/size=1024
lights_and_shadows/positional_shadow/atlas_size=1024
mesh_lod/lod_change/threshold_pixels=8.0
occlusion_culling/use_occlusion_culling=true

[dotnet]

project/assembly_name="RTSGame"
project/solution_path="RTS_Game.sln"
